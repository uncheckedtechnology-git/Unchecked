rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════
    // USERS — each user can only read/write their own doc
    // ═══════════════════════════════════════════
    match /users/{userId} {
      // Anyone logged in can read any user profile (needed for swipe cards)
      allow read: if request.auth != null;
      
      // Users can only write their own profile
      allow write: if request.auth != null && request.auth.uid == userId;

      // Subcollections: likes_sent, likes_received, passes
      match /likes_sent/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /likes_received/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /passes/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ═══════════════════════════════════════════
    // MATCHES — only participants can read/write
    // ═══════════════════════════════════════════
    match /matches/{matchId} {
      allow read: if request.auth != null 
        && request.auth.uid in resource.data.participants;
      
      // Allow create if user is one of the participants
      allow create: if request.auth != null 
        && request.auth.uid in request.resource.data.participants;
      
      // Allow update only by participants
      allow update: if request.auth != null 
        && request.auth.uid in resource.data.participants;
    }

    // ═══════════════════════════════════════════
    // CHATS — only match participants can read/send messages
    // ═══════════════════════════════════════════
    match /chats/{matchId}/messages/{msgId} {
      allow read, write: if request.auth != null;
      // Note: For stronger security, check if user is a participant
      // of the parent match document. This requires a get() call.
    }

    // ═══════════════════════════════════════════
    // SWIPES — only the swiper can write
    // ═══════════════════════════════════════════
    match /swipes/{swipeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ═══════════════════════════════════════════
    // REPORTS & BLOCKS — any logged-in user can create
    // ═══════════════════════════════════════════
    match /reports/{reportId} {
      allow create: if request.auth != null;
      allow read: if false; // Only admin/backend should read reports
    }
    match /blocks/{blockId} {
      allow create: if request.auth != null;
      allow read: if false; // Only admin/backend should read blocks
    }

    // ═══════════════════════════════════════════
    // APP CONFIG — public config readable, admin locked
    // ═══════════════════════════════════════════
    match /app_config/public {
      allow read: if request.auth != null;
      allow write: if false; // Only through Firebase Console or admin SDK
    }
    match /app_config/admin {
      allow read, write: if false; // LOCKED — manage through Firebase Console only
    }

    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
